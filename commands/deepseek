#!/usr/bin/env python3
"""
Claude-DeepSeek Bridge — /deepseek
Delegates routine tasks to DeepSeek V4 Flash (deepseek-chat).

Usage inside Claude Code:
    /deepseek Write a FastAPI endpoint for user CRUD operations.
"""

import sys
import os
import requests

DEEPSEEK_API_URL = "https://api.deepseek.com/v1/chat/completions"
MODEL = "deepseek-chat"  # Fast, cheap — perfect for boilerplate and routine work.


def main():
    if len(sys.argv) < 2:
        print("Usage: /deepseek <your prompt>")
        print("Example: /deepseek Generate Pydantic models for a blog post schema.")
        sys.exit(1)

    prompt = " ".join(sys.argv[1:])
    api_key = os.getenv("DEEPSEEK_API_KEY")

    if not api_key:
        print("Error: DEEPSEEK_API_KEY environment variable is not set.")
        print("Run: export DEEPSEEK_API_KEY='your-key-here'")
        print("Or re-run: bash setup.sh")
        sys.exit(1)

    try:
        response = requests.post(
            DEEPSEEK_API_URL,
            headers={
                "Authorization": f"Bearer {api_key}",
                "Content-Type": "application/json",
            },
            json={
                "model": MODEL,
                "messages": [{"role": "user", "content": prompt}],
                "temperature": 0.7,
            },
            timeout=30,
        )
    except requests.exceptions.RequestException as e:
        print(f"Error: Could not reach DeepSeek API — {e}")
        sys.exit(1)

    if response.status_code == 200:
        result = response.json()["choices"][0]["message"]["content"]
        print(result)
    else:
        print(f"DeepSeek API error ({response.status_code}): {response.text}")
        sys.exit(1)


if __name__ == "__main__":
    main()