#!/usr/bin/env python3
"""
Claude-DeepSeek Bridge — /deepseek-pro
Delegates moderate-complexity tasks to DeepSeek V4 Pro (deepseek-v4-pro).

Usage inside Claude Code:
    /deepseek-pro Identify potential race conditions in this async Python code.
"""

import sys
import os
import requests

DEEPSEEK_API_URL = "https://api.deepseek.com/v1/chat/completions"
# Update this if DeepSeek releases the Pro model under a different ID.
MODEL = "deepseek-v4-pro"  # High-reasoning model for complex analysis. (deepseek-reasoner deprecated 2026/07/24)


def main():
    if len(sys.argv) < 2:
        print("Usage: /deepseek-pro <complex prompt>")
        print("Example: /deepseek-pro Review this SQL query for performance bottlenecks.")
        sys.exit(1)

    prompt = " ".join(sys.argv[1:])
    api_key = os.getenv("DEEPSEEK_API_KEY")

    if not api_key:
        print("Error: DEEPSEEK_API_KEY environment variable is not set.")
        print("Run: export DEEPSEEK_API_KEY='your-key-here'")
        print("Or re-run: bash setup.sh")
        sys.exit(1)

    try:
        response = requests.post(
            DEEPSEEK_API_URL,
            headers={
                "Authorization": f"Bearer {api_key}",
                "Content-Type": "application/json",
            },
            json={
                "model": MODEL,
                "messages": [{"role": "user", "content": prompt}],
                "temperature": 0.5,
            },
            timeout=60,
        )
    except requests.exceptions.RequestException as e:
        print(f"Error: Could not reach DeepSeek API — {e}")
        sys.exit(1)

    if response.status_code == 200:
        result = response.json()["choices"][0]["message"]["content"]
        print(result)
    else:
        print(f"DeepSeek API error ({response.status_code}): {response.text}")
        sys.exit(1)


if __name__ == "__main__":
    main()